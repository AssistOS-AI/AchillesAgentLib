{
  "testCases": [
    {
      "description": "Relative links without leading slash get leading slash added",
      "input": [
        "about",
        "contact",
        "products/item"
      ],
      "expected": [
        "/about",
        "/contact",
        "/products/item"
      ]
    },
    {
      "description": "Relative links already with leading slash remain unchanged",
      "input": [
        "/about",
        "/contact",
        "/products/item"
      ],
      "expected": [
        "/about",
        "/contact",
        "/products/item"
      ]
    },
    {
      "description": "Absolute HTTP/HTTPS URLs are unchanged",
      "input": [
        "http://example.com",
        "https://example.com/path",
        "HTTP://example.com"
      ],
      "expected": [
        "http://example.com",
        "https://example.com/path",
        "HTTP://example.com"
      ]
    },
    {
      "description": "Empty array input returns empty array",
      "input": [],
      "expected": []
    },
    {
      "description": "Mixed array processes each correctly",
      "input": [
        "about",
        "/contact",
        "http://example.com",
        "products/item",
        "https://secure.com"
      ],
      "expected": [
        "/about",
        "/contact",
        "http://example.com",
        "/products/item",
        "https://secure.com"
      ]
    },
    {
      "description": "Non-http absolute URLs (ftp, mailto) get leading slash added",
      "input": [
        "ftp://example.com",
        "mailto:test@example.com",
        "file:///path"
      ],
      "expected": [
        "/ftp://example.com",
        "/mailto:test@example.com",
        "/file:///path"
      ]
    },
    {
      "description": "Edge case: http in middle of string",
      "input": [
        "pathhttp",
        "myhttp://path"
      ],
      "expected": [
        "/pathhttp",
        "/myhttp://path"
      ]
    },
    {
      "description": "Edge case: empty strings in array",
      "input": [
        "",
        "/",
        "path"
      ],
      "expected": [
        "/",
        "/",
        "/path"
      ]
    }
  ]
}
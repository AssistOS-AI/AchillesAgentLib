{
  "testCases": [
    {
      "description": "Successful scrape with mixed links (absolute, relative, duplicates)",
      "sourceKey": "test-page-1",
      "html": "<html><body><a href=\"/home\">Home</a><a href='http://example.com/about'>About</a><a href=\"/home\">Home Again</a><a href=\"contact\">Contact</a><a href=\"/HOME\">Home Uppercase</a><a href=\"http://Example.com/About\">About with caps</a></body></html>",
      "expected": [
        "/home",
        "http://example.com/about",
        "/contact",
        "/HOME",
        "http://Example.com/About"
      ]
    },
    {
      "description": "Source not found should propagate error from fetcher",
      "sourceKey": "non-existent-key",
      "html": null,
      "expectedError": "Source not found",
      "expected": "Source not found"
    },
    {
      "description": "Empty page returns empty array",
      "sourceKey": "empty-page",
      "html": "<html><body>No links here</body></html>",
      "expected": []
    },
    {
      "description": "Links with various formats and ordering",
      "sourceKey": "test-page-2",
      "html": "<html><body><a href=\"b\">B</a><a href=\"a\">A</a><a href=\"b\">B again</a><a href=\"c\">C</a><a href=\"A\">A uppercase</a><a href=\"https://external.com\">External</a></body></html>",
      "expected": [
        "/b",
        "/a",
        "/c",
        "/A",
        "https://external.com"
      ]
    }
  ]
}